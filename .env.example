# Neon Postgres — get from Neon console > Connection Details > Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_random_32_byte_base64_string

# NextAuth — public URL of the app (localhost for dev, Vercel URL for prod)
AUTH_URL=http://localhost:3000

# Google OAuth — from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
